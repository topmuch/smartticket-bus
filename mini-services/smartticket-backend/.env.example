# ============================================
# SmartTicket Bus - Configuration Serveur
# ============================================
# Copiez ce fichier en .env et modifiez les valeurs

# --- Serveur ---
PORT=3001
NODE_ENV=development

# --- JWT (Authentification) ---
# Générez une clé forte : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGEZ_MOI_PAR_UNE_CLE_SECRETE_FORTE
JWT_REFRESH_SECRET=CHANGEZ_MOI_PAR_UNE_AUTRE_CLE_SECRETE
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
# En production: https://smartticket.bus,https://admin.smartticket.bus
CORS_ORIGINS=*

# --- Rate Limiting ---
LOGIN_RATE_MAX=5
LOGIN_RATE_WINDOW_MS=900000

# --- Base de données ---
# SQLite (sql.js) - chemin relatif au dossier mini-services/smartticket-backend/
# DB_PATH=./data/smartticket.db
